<?xml version="1.0" encoding="UTF-8"?>
<!--
  OSGi Configuration for PrivateFolderPermissionChangeListener

  This configuration file allows administrators to:
  1. Enable/disable the permission change listener
  2. Configure the root path to monitor
  3. Configure which event types to listen for
  4. Configure whether to monitor nested paths

  Place this file in one of these locations:
  - /apps/catcsc/osgiconfig/config/ (for all instances)
  - /apps/catcsc/osgiconfig/config.author/ (for author instances only)
  - /apps/catcsc/osgiconfig/config.publish/ (for publish instances only)

  The PID (Persistent ID) is: com.cat.csc.core.listeners.PrivateFolderPermissionChangeListener
-->
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="sling:OsgiConfig"
          enabled="{Boolean}true"
          monitoredRootPath="/content/dam"
          monitorPropertyChanges="{Boolean}true"
          monitorPropertyAdditions="{Boolean}true"
          monitorPropertyRemovals="{Boolean}true"
          monitorNestedPaths="{Boolean}true"
          logLevel="INFO"/>

<!--
Configuration Properties:

ENABLED (Boolean, default: true)
  - Enable or disable the permission change listener
  - When set to false, the listener will not be activated and no events will be monitored
  - Useful for temporary disabling the listener without uninstalling the bundle

  Example:
    <enabled>{Boolean}false</enabled>

MONITORED_ROOT_PATH (String, default: /content/dam)
  - The repository path to monitor for permission changes
  - The listener will monitor all nested paths under this root path (unless monitorNestedPaths is false)

  Common values:
    - /content/dam (monitor all DAM content)
    - /content/dam/private (monitor only private folders)
    - /content (monitor all content under /content)
    - /content/dam/company-a (monitor company-specific content)

  Example:
    <monitoredRootPath>/content/dam/private</monitoredRootPath>

MONITOR_PROPERTY_CHANGES (Boolean, default: true)
  - Monitor PROPERTY_CHANGED events
  - Detects when existing permission properties are modified

  Example:
    <monitorPropertyChanges>{Boolean}true</monitorPropertyChanges>

MONITOR_PROPERTY_ADDITIONS (Boolean, default: true)
  - Monitor PROPERTY_ADDED events
  - Detects when new permission properties are added

  Example:
    <monitorPropertyAdditions>{Boolean}true</monitorPropertyAdditions>

MONITOR_PROPERTY_REMOVALS (Boolean, default: true)
  - Monitor PROPERTY_REMOVED events
  - Detects when permission properties are removed

  Example:
    <monitorPropertyRemovals>{Boolean}true</monitorPropertyRemovals>

MONITOR_NESTED_PATHS (Boolean, default: true)
  - Monitor nested child paths
  - true: monitor all child paths under the root path
  - false: only direct changes to the root path itself

  Example:
    <monitorNestedPaths>{Boolean}true</monitorNestedPaths>

LOG_LEVEL (String, valid values: DEBUG, INFO, WARN, ERROR, default: INFO)
  - Controls the verbosity of logging output from the listener
  - DEBUG: Detailed logging including every event filtered
  - INFO: Standard logging, only important events
  - WARN: Only warning and error messages
  - ERROR: Only error messages

  Example:
    <logLevel>DEBUG</logLevel>

COMPLETE EXAMPLES:

1. Monitor only /content/dam/private with all events:
   <jcr:root ...
             enabled="{Boolean}true"
             monitoredRootPath="/content/dam/private"
             monitorPropertyChanges="{Boolean}true"
             monitorPropertyAdditions="{Boolean}true"
             monitorPropertyRemovals="{Boolean}true"
             monitorNestedPaths="{Boolean}true"
             logLevel="INFO"/>

2. Monitor all of /content but only PROPERTY_CHANGED events:
   <jcr:root ...
             enabled="{Boolean}true"
             monitoredRootPath="/content"
             monitorPropertyChanges="{Boolean}true"
             monitorPropertyAdditions="{Boolean}false"
             monitorPropertyRemovals="{Boolean}false"
             monitorNestedPaths="{Boolean}true"
             logLevel="INFO"/>

3. Disable the listener temporarily:
   <jcr:root ...
             enabled="{Boolean}false"
             monitoredRootPath="/content/dam"
             .../>

4. Enable debug logging for troubleshooting:
   <jcr:root ...
             ...
             logLevel="DEBUG"/>
-->

